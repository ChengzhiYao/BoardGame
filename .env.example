# ============================================================
# 复制本文件为 .env.local，把下面的占位符换成你的真实值。
# 注意：带 SERVICE_ROLE / API_KEY 的都是机密，绝不能提交到 git，
# 也绝不会下发到前端（只在服务端用）。
# ============================================================

# ---- Supabase（项目 → Settings → API 里能找到）----
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...        # 公开 anon key，前端用
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # 机密！只服务端用，能绕过 RLS 读真相

# ---- 大模型（两家都填，可在后台/设置里切换）----
LLM_PROVIDER=anthropic                      # anthropic 或 openai，默认主模型用哪家
ANTHROPIC_API_KEY=sk-ant-...                # Claude
OPENAI_API_KEY=sk-...                       # GPT

# 主/副模型分层（副模型做摘要/分类等轻任务，省钱）。型号名以官网最新为准。
LLM_MAIN_MODEL=claude-...                    # 强模型：真相生成、回合主持
LLM_AUX_MODEL=gpt-...                        # 便宜快模型：记忆摘要、配图 prompt

# ---- 图片生成 ----
IMAGE_PROVIDER=openai                        # openai 或其他
IMAGE_API_KEY=sk-...                         # 可与上面复用

# ---- 站点 ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000   # 部署后改成正式域名（邀请链接用）
